# Visual Studio 2015 user specific files
SG/.vs/

# Compiled Object files
SG/*.slo
SG/*.lo
SG/*.o
SG/*.obj
SG/.idea

# Precompiled Headers
SG/*.gch
SG/*.pch

# Compiled Dynamic libraries
SG/*.so
SG/*.dylib
SG/*.dll

# Fortran module files
SG/*.mod

# Compiled Static libraries
SG/*.lai
SG/*.la
SG/*.a
SG/*.lib

# Executables
SG/*.exe
SG/*.out
SG/*.app
SG/*.ipa

# These project files can be generated by the engine
SG/*.xcodeproj
SG/*.xcworkspace
SG/*.sln
SG/*.suo
SG/*.opensdf
SG/*.sdf
SG/*.VC.db
SG/*.VC.opendb

# Precompiled Assets
SG/SourceArt/**/*.png
SG/SourceArt/**/*.tga

# Binary Files
SG/Binaries/*
SG/Plugins/**/Binaries/*

# Builds
SG/Build/*

# Whitelist PakBlacklist-<BuildConfiguration>.txt files
SG/!Build/*/
SG/Build/*/**
SG/!Build/*/PakBlacklist*.txt

# Don't ignore icon files in Build
SG/!Build/**/*.ico

# Built data for maps
SG/*_BuiltData.uasset

# Configuration files generated by the Editor
SG/Saved/*

# Compiled source files for the engine to use
SG/Intermediate/*
SG/Plugins/**/Intermediate/*

# Cache files for the editor to use
SG/DerivedDataCache/*

# Don't ignore icon and splash images for mobile app
SG/!Build/IOS/Resources/
SG/Build/IOS/Resources/*
SG/!Build/IOS/Resources/Graphics/
SG/Build/IOS/Resources/Graphics/*
SG/!Build/IOS/Resources/Graphics/*.png
SG/!Build/Android/res/
SG/Build/Android/res/*
SG/!Build/Android/res/*/
SG/Build/Android/res/*/*
SG/!Build/Android/res/*/*.png
SG/# Ignore plugins binaries on deep subfolders
SG/Plugins/**/Binaries/*
SG/Plugins/**/Intermediate/*